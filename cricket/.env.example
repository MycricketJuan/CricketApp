# ============================================================
# CRICKET — Variables de entorno
# Copiar a .env.local para desarrollo
# ============================================================

# ── Supabase (obtener en: supabase.com → Project Settings → API) ──
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ⚠️ SOLO en services/api — NUNCA en apps/dashboard ni widget
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase project ref (para CLI: supabase link --project-ref)
SUPABASE_PROJECT_REF=xxxxxxxxxxxxxxxxxxxx

# ── Anthropic (obtener en: console.anthropic.com) ──
# ⚠️ SOLO en services/api — NUNCA en cliente
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Multi-tenancy (desarrollo local) ──
# Slug del tenant usado cuando no hay subdominio (localhost)
DEV_TENANT_SLUG=banco-dev

# URL base del dashboard (sin subdominio)
NEXT_PUBLIC_BASE_URL=mycricket.ai
NEXT_PUBLIC_DASHBOARD_PORT=3000

# ── Canales (Phase 1: WhatsApp + Email) ──
# WhatsApp Cloud API (Meta for Developers → App → WhatsApp)
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=

# Email (Resend — resend.com)
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@mycricket.ai

# ── API interna ──
API_PORT=3001
API_SECRET=                  # HMAC secret para verificar webhooks internos
