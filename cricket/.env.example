# ============================================================
# CRICKET — Variables de entorno
# Copiar a .env.local para desarrollo
# ============================================================

# ── Supabase (obtener en: supabase.com → Project Settings → API) ──
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ⚠️ SOLO en services/api — NUNCA en apps/dashboard ni widget
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase project ref (para CLI: supabase link --project-ref)
SUPABASE_PROJECT_REF=xxxxxxxxxxxxxxxxxxxx

# ── Anthropic (obtener en: console.anthropic.com) ──
# ⚠️ SOLO en services/api — NUNCA en cliente
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Multi-tenancy (desarrollo local) ──
# Slug del tenant usado cuando no hay subdominio (localhost)
DEV_TENANT_SLUG=banco-dev

# URL base del dashboard (sin subdominio)
NEXT_PUBLIC_BASE_URL=mycricket.ai
NEXT_PUBLIC_DASHBOARD_PORT=3000

# ── Canales (Phase 1: WhatsApp vía Twilio + Email) ──
# Twilio (console.twilio.com → Account Info)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=                   # Usado para validar X-Twilio-Signature en el webhook
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886   # Número remitente (sandbox o producción)

# Email (Resend — resend.com)
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@mycricket.ai

# ── Auth0 (manage.auth0.com → Applications → Regular Web Application) ──
# Obtener en: Auth0 Dashboard → Settings
AUTH0_DOMAIN=YOUR_TENANT.auth0.com
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_SECRET=                # 32+ bytes hex — generar con: openssl rand -hex 32
APP_BASE_URL=http://localhost:3000   # En producción: https://app.mycricket.ai
# Compartir sesión entre app.mycricket.ai y los subdominios de clientes.
# No definir en desarrollo local; en producción usar: AUTH0_COOKIE_DOMAIN=.mycricket.ai
CRICKET_ROOT_DOMAIN=mycricket.ai
# Registrar en Auth0: Allowed Callback URLs → http://localhost:3000/auth/callback
#                                              https://app.mycricket.ai/auth/callback
#                     Allowed Logout URLs   → http://localhost:3000
#                                              https://app.mycricket.ai
# Activar sign-ups y verificación de email en la Database Connection de Auth0.

# ── API interna ──
API_PORT=3001
API_SECRET=                  # HMAC secret para verificar webhooks internos
