{
  "name": "cricket",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.4.0",
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "dev": "pnpm --parallel --filter './apps/**' --filter './services/**' dev",
    "build": "pnpm --filter './packages/**' build && pnpm --filter './apps/**' --filter './services/**' build",
    "type-check": "pnpm -r type-check",
    "db:types": "supabase gen types typescript --project-id $SUPABASE_PROJECT_REF --schema public > packages/core/src/types/supabase.generated.ts && echo '✓ tipos generados'",
    "db:push": "supabase db push",
    "db:studio": "supabase studio",
    "db:reset": "supabase db reset"
  },
  "devDependencies": {
    "supabase": "^1.200.0",
    "typescript": "^5.5.0"
  }
}
